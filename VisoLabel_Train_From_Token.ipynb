   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {\n",
    "    \"id\": \"visolabel_intro\"\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# VisoLabel Colab Trainer\\n\",\n",
    "    \"\\n\",\n",
    "    \"Use this notebook when VisoLabel gives you a Colab training token. The notebook opens a GUI where you can paste the token, inspect the resolved training bundle, start training, watch progress, and upload the checkpoints back to VisoLabel.\\n\",\n",
    "    \"\\n\",\n",
    "    \"## How to use it\\n\",\n",
    "    \"\\n\",\n",
    "    \"1. In VisoLabel, choose `Train on Colab` and copy the generated token.\\n\",\n",
    "    \"2. In Colab, set the runtime to GPU from `Runtime > Change runtime type`.\\n\",\n",
    "    \"3. Run the single cell below named `Launch VisoLabel Training GUI`.\\n\",\n",
    "    \"4. Paste the token into the GUI and click `Run full pipeline`.\\n\",\n",
    "    \"5. Keep the tab open until the status changes to `Complete`.\\n\",\n",
    "    \"\\n\",\n",
    "    \"The token is a secret. For encrypted handoffs it contains the server token and the decryption password, so do not share it.\\n\",\n",
    "    \"\\n\",\n",
    "    \"## GUI features\\n\",\n",
    "    \"\\n\",\n",
    "    \"- Token input field with optional API URL override for private API deployments.\\n\",\n",
    "    \"- Bundle preview showing task, model, epochs, batch size, image size, class count, and dataset image count.\\n\",\n",
    "    \"- One-click full pipeline plus separate resolve, train, and upload controls for troubleshooting.\\n\",\n",
    "    \"- Progress bar, status cards, and live logs for download, decryption, extraction, training, and upload.\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {\n",
    "    \"id\": \"visolabel_gui_launcher\",\n",
    "    \"cellView\": \"form\"\n",
    "   },\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"#@title Launch VisoLabel Training GUI { display-mode: \\\"form\\\" }\\n\",\n",
    "    \"#@markdown Run this cell once. The implementation is hidden so the notebook stays focused on the GUI.\\n\",\n",
    "    \"!pip -q install requests tqdm cryptography ipywidgets\\n\",\n",
    "    \"\\n\",\n",
    "    \"import base64\\n\",\n",
    "    \"import hashlib\\n\",\n",
    "    \"import html\\n\",\n",
    "    \"import json\\n\",\n",
    "    \"import os\\n\",\n",
    "    \"import shutil\\n\",\n",
    "    \"import subprocess\\n\",\n",
    "    \"import sys\\n\",\n",
    "    \"import time\\n\",\n",
    "    \"import zipfile\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"import requests\\n\",\n",
    "    \"from IPython.display import HTML, clear_output, display\\n\",\n",
    "    \"from cryptography.hazmat.primitives import hashes\\n\",\n",
    "    \"from cryptography.hazmat.primitives.ciphers import Cipher, algorithms, modes\\n\",\n",
    "    \"from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC\\n\",\n",
    "    \"from tqdm.auto import tqdm\\n\",\n",
    "    \"\\n\",\n",
    "    \"try:\\n\",\n",
    "    \"    from google.colab import output as colab_output\\n\",\n",
    "    \"    colab_output.enable_custom_widget_manager()\\n\",\n",
    "    \"except Exception:\\n\",\n",
    "    \"    pass\\n\",\n",
    "    \"\\n\",\n",
    "    \"import ipywidgets as widgets\\n\",\n",
    "    \"\\n\",\n",
    "    \"DEFAULT_API_BASE_URL = os.environ.get(\\\"VISOLABEL_API_BASE\\\", \\\"https://api.visolabel.ovh\\\")\\n\",\n",
    "    \"TOKEN_PREFIX = \\\"VL1.\\\"\\n\",\n",
    "    \"LEGACY_TOKEN_PREFIX = \\\"VL-COLAB-ENC1.\\\"\\n\",\n",
    "    \"WORK_DIR = Path(\\\"/content/visolabel_run\\\")\\n\",\n",
    "    \"BUNDLE_ENCRYPTED = WORK_DIR / \\\"bundle.zip.vlenc\\\"\\n\",\n",
    "    \"BUNDLE_ZIP = WORK_DIR / \\\"bundle.zip\\\"\\n\",\n",
    "    \"BUNDLE_DIR = WORK_DIR / \\\"bundle\\\"\\n\",\n",
    "    \"OUTPUT_DIR = WORK_DIR / \\\"output\\\"\\n\",\n",
    "    \"IMAGE_EXTENSIONS = {\\\".jpg\\\", \\\".jpeg\\\", \\\".png\\\", \\\".bmp\\\", \\\".webp\\\", \\\".tif\\\", \\\".tiff\\\"}\\n\",\n",
    "    \"ARTIFACT_EXTENSIONS = {\\\".pth\\\", \\\".pt\\\", \\\".onnx\\\", \\\".log\\\", \\\".json\\\", \\\".yaml\\\", \\\".yml\\\", \\\".txt\\\"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"for directory in (WORK_DIR, OUTPUT_DIR):\\n\",\n",
    "    \"    directory.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _b64url_decode(value: str) -> bytes:\\n\",\n",
    "    \"    return base64.urlsafe_b64decode((value + \\\"=\\\" * (-len(value) % 4)).encode(\\\"ascii\\\"))\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _b64decode(value: str) -> bytes:\\n\",\n",
    "    \"    return base64.b64decode(value.encode(\\\"ascii\\\"), validate=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _sha256(path: Path) -> str:\\n\",\n",
    "    \"    digest = hashlib.sha256()\\n\",\n",
    "    \"    with open(path, \\\"rb\\\") as f:\\n\",\n",
    "    \"        for chunk in iter(lambda: f.read(1024 * 1024), b\\\"\\\"):\\n\",\n",
    "    \"            digest.update(chunk)\\n\",\n",
    "    \"    return digest.hexdigest()\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _normalize_encryption_metadata(value: dict) -> dict:\\n\",\n",
    "    \"    if not isinstance(value, dict) or not value:\\n\",\n",
    "    \"        return {}\\n\",\n",
    "    \"    if value.get(\\\"salt_b64\\\") and value.get(\\\"nonce_b64\\\") and value.get(\\\"tag_b64\\\"):\\n\",\n",
    "    \"        return value\\n\",\n",
    "    \"    metadata = {\\n\",\n",
    "    \"        \\\"enabled\\\": True,\\n\",\n",
    "    \"        \\\"algorithm\\\": value.get(\\\"algorithm\\\", \\\"AES-256-GCM\\\"),\\n\",\n",
    "    \"        \\\"kdf\\\": value.get(\\\"kdf\\\", \\\"PBKDF2-HMAC-SHA256\\\"),\\n\",\n",
    "    \"        \\\"kdf_iterations\\\": value.get(\\\"kdf_iterations\\\") or value.get(\\\"i\\\") or 200000,\\n\",\n",
    "    \"        \\\"salt_b64\\\": value.get(\\\"s\\\") or value.get(\\\"salt\\\") or value.get(\\\"salt_b64\\\", \\\"\\\"),\\n\",\n",
    "    \"        \\\"nonce_b64\\\": value.get(\\\"n\\\") or value.get(\\\"nonce\\\") or value.get(\\\"nonce_b64\\\", \\\"\\\"),\\n\",\n",
    "    \"        \\\"tag_b64\\\": value.get(\\\"g\\\") or value.get(\\\"tag\\\") or value.get(\\\"tag_b64\\\", \\\"\\\"),\\n\",\n",
    "    \"        \\\"aad_b64\\\": value.get(\\\"a\\\") or value.get(\\\"aad_b64\\\") or base64.b64encode(b\\\"visolabel-colab-bundle-v1\\\").decode(\\\"ascii\\\"),\\n\",\n",
    "    \"        \\\"plaintext_sha256\\\": value.get(\\\"ps\\\") or value.get(\\\"plaintext_sha256\\\", \\\"\\\"),\\n\",\n",
    "    \"        \\\"ciphertext_sha256\\\": value.get(\\\"cs\\\") or value.get(\\\"ciphertext_sha256\\\", \\\"\\\"),\\n\",\n",
    "    \"        \\\"plaintext_size\\\": value.get(\\\"psz\\\") or value.get(\\\"plaintext_size\\\", 0),\\n\",\n",
    "    \"        \\\"ciphertext_size\\\": value.get(\\\"csz\\\") or value.get(\\\"ciphertext_size\\\", 0),\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"    if not metadata[\\\"salt_b64\\\"] or not metadata[\\\"nonce_b64\\\"] or not metadata[\\\"tag_b64\\\"]:\\n\",\n",
    "    \"        return {}\\n\",\n",
    "    \"    return metadata\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _extract_bundle_url(value: dict) -> str:\\n\",\n",
    "    \"    if not isinstance(value, dict):\\n\",\n",
    "    \"        return \\\"\\\"\\n\",\n",
    "    \"    for key in (\\\"bundle_url\\\", \\\"download_url\\\", \\\"presigned_download_url\\\", \\\"s3_url\\\", \\\"url\\\"):\\n\",\n",
    "    \"        found = str(value.get(key) or \\\"\\\")\\n\",\n",
    "    \"        if found:\\n\",\n",
    "    \"            return found\\n\",\n",
    "    \"    for key in (\\\"bundle\\\", \\\"upload\\\", \\\"data\\\", \\\"result\\\"):\\n\",\n",
    "    \"        found = _extract_bundle_url(value.get(key) or {})\\n\",\n",
    "    \"        if found:\\n\",\n",
    "    \"            return found\\n\",\n",
    "    \"    return \\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _extract_encryption_metadata(value: dict) -> dict:\\n\",\n",
    "    \"    if not isinstance(value, dict):\\n\",\n",
    "    \"        return {}\\n\",\n",
    "    \"    direct = _normalize_encryption_metadata(value.get(\\\"encryption\\\") or value.get(\\\"encryption_metadata\\\") or value.get(\\\"e\\\") or {})\\n\",\n",
    "    \"    if direct:\\n\",\n",
    "    \"        return direct\\n\",\n",
    "    \"    metadata = _normalize_encryption_metadata(value)\\n\",\n",
    "    \"    if metadata:\\n\",\n",
    "    \"        return metadata\\n\",\n",
    "    \"    for key in (\\\"bundle\\\", \\\"upload\\\", \\\"data\\\", \\\"result\\\"):\\n\",\n",
    "    \"        metadata = _extract_encryption_metadata(value.get(key) or {})\\n\",\n",
    "    \"        if metadata:\\n\",\n",
    "    \"            return metadata\\n\",\n",
    "    \"    return {}\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _safe_extract_zip(zip_path: Path, destination: Path) -> None:\\n\",\n",
    "    \"    destination = destination.resolve()\\n\",\n",
    "    \"    with zipfile.ZipFile(zip_path, \\\"r\\\") as zf:\\n\",\n",
    "    \"        for member in zf.infolist():\\n\",\n",
    "    \"            target = (destination / member.filename).resolve()\\n\",\n",
    "    \"            if destination != target and destination not in target.parents:\\n\",\n",
    "    \"                raise RuntimeError(f\\\"Unsafe path in bundle: {member.filename}\\\")\\n\",\n",
    "    \"        zf.extractall(destination)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _install_package(package: str) -> None:\\n\",\n",
    "    \"    subprocess.check_call([sys.executable, \\\"-m\\\", \\\"pip\\\", \\\"install\\\", \\\"-q\\\", package])\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _count_images(root: Path) -> int:\\n\",\n",
    "    \"    if not root.exists():\\n\",\n",
    "    \"        return 0\\n\",\n",
    "    \"    return sum(1 for p in root.rglob(\\\"*\\\") if p.is_file() and p.suffix.lower() in IMAGE_EXTENSIONS)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _format_bytes(value: int) -> str:\\n\",\n",
    "    \"    size = float(value)\\n\",\n",
    "    \"    for unit in (\\\"B\\\", \\\"KB\\\", \\\"MB\\\", \\\"GB\\\"):\\n\",\n",
    "    \"        if size < 1024 or unit == \\\"GB\\\":\\n\",\n",
    "    \"            return f\\\"{size:.1f} {unit}\\\" if unit != \\\"B\\\" else f\\\"{int(size)} B\\\"\\n\",\n",
    "    \"        size /= 1024\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class VisoLabelColabGUI:\\n\",\n",
    "    \"    def __init__(self):\\n\",\n",
    "    \"        self.api_base_url = DEFAULT_API_BASE_URL\\n\",\n",
    "    \"        self.token_value = \\\"\\\"\\n\",\n",
    "    \"        self.api_token = \\\"\\\"\\n\",\n",
    "    \"        self.manifest = None\\n\",\n",
    "    \"        self.cfg = {}\\n\",\n",
    "    \"        self.task = \\\"\\\"\\n\",\n",
    "    \"        self.command = \\\"\\\"\\n\",\n",
    "    \"        self.dataset_dir = None\\n\",\n",
    "    \"        self.upload_list = []\\n\",\n",
    "    \"        self.encrypted = False\\n\",\n",
    "    \"        self.training_finished = False\\n\",\n",
    "    \"        self.started_at = None\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.token = widgets.Password(\\n\",\n",
    "    \"            description=\\\"Token\\\",\\n\",\n",
    "    \"            placeholder=\\\"Paste the token copied from VisoLabel\\\",\\n\",\n",
    "    \"            layout=widgets.Layout(width=\\\"100%\\\"),\\n\",\n",
    "    \"            style={\\\"description_width\\\": \\\"70px\\\"},\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"        self.api_url = widgets.Text(\\n\",\n",
    "    \"            value=DEFAULT_API_BASE_URL,\\n\",\n",
    "    \"            description=\\\"API URL\\\",\\n\",\n",
    "    \"            layout=widgets.Layout(width=\\\"100%\\\"),\\n\",\n",
    "    \"            style={\\\"description_width\\\": \\\"70px\\\"},\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"        self.progress = widgets.FloatProgress(\\n\",\n",
    "    \"            value=0,\\n\",\n",
    "    \"            min=0,\\n\",\n",
    "    \"            max=100,\\n\",\n",
    "    \"            description=\\\"Progress\\\",\\n\",\n",
    "    \"            bar_style=\\\"\\\",\\n\",\n",
    "    \"            layout=widgets.Layout(width=\\\"100%\\\"),\\n\",\n",
    "    \"            style={\\\"description_width\\\": \\\"75px\\\"},\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"        self.status = widgets.HTML()\\n\",\n",
    "    \"        self.summary = widgets.HTML()\\n\",\n",
    "    \"        self.log_output = widgets.Output(layout=widgets.Layout(border=\\\"1px solid #d0d7de\\\", height=\\\"320px\\\", overflow_y=\\\"auto\\\"))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.run_button = widgets.Button(description=\\\"Run full pipeline\\\", button_style=\\\"primary\\\", layout=widgets.Layout(width=\\\"170px\\\"))\\n\",\n",
    "    \"        self.resolve_button = widgets.Button(description=\\\"Resolve bundle\\\", layout=widgets.Layout(width=\\\"145px\\\"))\\n\",\n",
    "    \"        self.train_button = widgets.Button(description=\\\"Start training\\\", layout=widgets.Layout(width=\\\"145px\\\"), disabled=True)\\n\",\n",
    "    \"        self.upload_button = widgets.Button(description=\\\"Upload results\\\", layout=widgets.Layout(width=\\\"145px\\\"), disabled=True)\\n\",\n",
    "    \"        self.clear_button = widgets.Button(description=\\\"Clear logs\\\", layout=widgets.Layout(width=\\\"115px\\\"))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.run_button.on_click(self._on_run_full)\\n\",\n",
    "    \"        self.resolve_button.on_click(self._on_resolve)\\n\",\n",
    "    \"        self.train_button.on_click(self._on_train)\\n\",\n",
    "    \"        self.upload_button.on_click(self._on_upload)\\n\",\n",
    "    \"        self.clear_button.on_click(lambda _: self.log_output.clear_output())\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self._set_status(\\\"Waiting for token\\\", \\\"Paste a VisoLabel token, then run the full pipeline.\\\", \\\"idle\\\")\\n\",\n",
    "    \"        self._render_summary()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def display(self):\\n\",\n",
    "    \"        clear_output(wait=True)\\n\",\n",
    "    \"        display(HTML(self._style()))\\n\",\n",
    "    \"        display(widgets.VBox([\\n\",\n",
    "    \"            widgets.HTML(self._header()),\\n\",\n",
    "    \"            widgets.VBox([self.token, self.api_url], layout=widgets.Layout(gap=\\\"8px\\\")),\\n\",\n",
    "    \"            widgets.HBox([self.run_button, self.resolve_button, self.train_button, self.upload_button, self.clear_button], layout=widgets.Layout(gap=\\\"8px\\\", flex_flow=\\\"row wrap\\\")),\\n\",\n",
    "    \"            self.status,\\n\",\n",
    "    \"            self.progress,\\n\",\n",
    "    \"            self.summary,\\n\",\n",
    "    \"            widgets.HTML(\\\"<div class='vl-section-title'>Live logs</div>\\\"),\\n\",\n",
    "    \"            self.log_output,\\n\",\n",
    "    \"        ], layout=widgets.Layout(gap=\\\"12px\\\")))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _style(self):\\n\",\n",
    "    \"        return \\\"\\\"\\\"\\n\",\n",
    "    \"        <style>\\n\",\n",
    "    \"        .vl-hero {background:#111827;color:#ffffff;padding:18px 20px;border-radius:8px;border-left:6px solid #14b8a6;box-shadow:0 8px 24px rgba(17,24,39,.18);}\\n\",\n",
    "    \"        .vl-hero h2 {font-size:24px;line-height:1.2;margin:0 0 6px 0;letter-spacing:0;}\\n\",\n",
    "    \"        .vl-hero p {font-size:14px;line-height:1.45;margin:0;color:#d1d5db;}\\n\",\n",
    "    \"        .vl-section-title {font-size:13px;font-weight:700;color:#374151;margin-top:6px;text-transform:uppercase;letter-spacing:.04em;}\\n\",\n",
    "    \"        .vl-status {border:1px solid #d0d7de;border-radius:8px;padding:12px 14px;background:#ffffff;}\\n\",\n",
    "    \"        .vl-status strong {font-size:15px;color:#111827;}\\n\",\n",
    "    \"        .vl-status span {display:block;font-size:13px;color:#4b5563;margin-top:3px;}\\n\",\n",
    "    \"        .vl-idle {border-left:5px solid #64748b;}\\n\",\n",
    "    \"        .vl-active {border-left:5px solid #2563eb;}\\n\",\n",
    "    \"        .vl-ok {border-left:5px solid #16a34a;}\\n\",\n",
    "    \"        .vl-error {border-left:5px solid #dc2626;}\\n\",\n",
    "    \"        .vl-grid {display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px;margin-top:2px;}\\n\",\n",
    "    \"        .vl-card {border:1px solid #d0d7de;border-radius:8px;padding:12px;background:#ffffff;min-height:68px;}\\n\",\n",
    "    \"        .vl-label {font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;margin-bottom:5px;}\\n\",\n",
    "    \"        .vl-value {font-size:16px;font-weight:700;color:#111827;word-break:break-word;}\\n\",\n",
    "    \"        .vl-muted {font-size:12px;color:#6b7280;margin-top:4px;}\\n\",\n",
    "    \"        </style>\\n\",\n",
    "    \"        \\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _header(self):\\n\",\n",
    "    \"        return \\\"\\\"\\\"\\n\",\n",
    "    \"        <div class='vl-hero'>\\n\",\n",
    "    \"          <h2>VisoLabel Colab Trainer</h2>\\n\",\n",
    "    \"          <p>Paste a token, preview the bundle, train on the Colab GPU, and send checkpoints back to VisoLabel.</p>\\n\",\n",
    "    \"        </div>\\n\",\n",
    "    \"        \\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _set_status(self, title: str, detail: str = \\\"\\\", kind: str = \\\"active\\\"):\\n\",\n",
    "    \"        title = html.escape(title)\\n\",\n",
    "    \"        detail = html.escape(detail)\\n\",\n",
    "    \"        self.status.value = f\\\"<div class='vl-status vl-{kind}'><strong>{title}</strong><span>{detail}</span></div>\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _render_summary(self):\\n\",\n",
    "    \"        cfg = self.cfg or {}\\n\",\n",
    "    \"        classes = cfg.get(\\\"classes\\\") or []\\n\",\n",
    "    \"        if not isinstance(classes, list):\\n\",\n",
    "    \"            classes = []\\n\",\n",
    "    \"        dataset_count = _count_images(self.dataset_dir) if self.dataset_dir else 0\\n\",\n",
    "    \"        model_name = cfg.get(\\\"model_name\\\", \\\"-\\\")\\n\",\n",
    "    \"        epochs = cfg.get(\\\"epochs\\\", \\\"-\\\")\\n\",\n",
    "    \"        batch_size = cfg.get(\\\"batch_size\\\", \\\"-\\\")\\n\",\n",
    "    \"        image_size = cfg.get(\\\"image_size\\\", \\\"-\\\")\\n\",\n",
    "    \"        task_label = self.task or \\\"Not resolved\\\"\\n\",\n",
    "    \"        security = \\\"Encrypted\\\" if self.encrypted else (\\\"Legacy token\\\" if self.manifest else \\\"-\\\")\\n\",\n",
    "    \"        values = [\\n\",\n",
    "    \"            (\\\"Task\\\", task_label, self.command or \\\"Waiting\\\"),\\n\",\n",
    "    \"            (\\\"Model\\\", model_name, security),\\n\",\n",
    "    \"            (\\\"Epochs\\\", epochs, f\\\"Batch {batch_size}\\\"),\\n\",\n",
    "    \"            (\\\"Image size\\\", image_size, f\\\"{len(classes)} classes\\\"),\\n\",\n",
    "    \"            (\\\"Dataset\\\", f\\\"{dataset_count} images\\\", str(self.dataset_dir or \\\"-\\\")),\\n\",\n",
    "    \"        ]\\n\",\n",
    "    \"        cards = []\\n\",\n",
    "    \"        for label, value, muted in values:\\n\",\n",
    "    \"            cards.append(\\n\",\n",
    "    \"                \\\"<div class='vl-card'>\\\"\\n\",\n",
    "    \"                f\\\"<div class='vl-label'>{html.escape(str(label))}</div>\\\"\\n\",\n",
    "    \"                f\\\"<div class='vl-value'>{html.escape(str(value))}</div>\\\"\\n\",\n",
    "    \"                f\\\"<div class='vl-muted'>{html.escape(str(muted))}</div>\\\"\\n\",\n",
    "    \"                \\\"</div>\\\"\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"        self.summary.value = \\\"<div class='vl-grid'>\\\" + \\\"\\\".join(cards) + \\\"</div>\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _log(self, message: str):\\n\",\n",
    "    \"        with self.log_output:\\n\",\n",
    "    \"            print(f\\\"[{time.strftime('%H:%M:%S')}] {message}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _post(self, path: str, payload: dict) -> dict:\\n\",\n",
    "    \"        url = f\\\"{self.api_base_url.rstrip('/')}{path}\\\"\\n\",\n",
    "    \"        response = requests.post(url, json=payload, timeout=120)\\n\",\n",
    "    \"        response.raise_for_status()\\n\",\n",
    "    \"        return response.json()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _reset_run_files(self):\\n\",\n",
    "    \"        for path in (BUNDLE_ENCRYPTED, BUNDLE_ZIP):\\n\",\n",
    "    \"            try:\\n\",\n",
    "    \"                if path.exists():\\n\",\n",
    "    \"                    path.unlink()\\n\",\n",
    "    \"            except Exception as exc:\\n\",\n",
    "    \"                self._log(f\\\"Could not remove {path.name}: {exc}\\\")\\n\",\n",
    "    \"        for path in (BUNDLE_DIR, OUTPUT_DIR):\\n\",\n",
    "    \"            try:\\n\",\n",
    "    \"                if path.exists():\\n\",\n",
    "    \"                    shutil.rmtree(path)\\n\",\n",
    "    \"                path.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"            except Exception as exc:\\n\",\n",
    "    \"                self._log(f\\\"Could not reset {path}: {exc}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _download(self, url: str, destination: Path, start: float, end: float):\\n\",\n",
    "    \"        with requests.get(url, stream=True, timeout=600) as response:\\n\",\n",
    "    \"            response.raise_for_status()\\n\",\n",
    "    \"            total = int(response.headers.get(\\\"content-length\\\") or 0)\\n\",\n",
    "    \"            done = 0\\n\",\n",
    "    \"            with open(destination, \\\"wb\\\") as f:\\n\",\n",
    "    \"                for chunk in response.iter_content(chunk_size=1024 * 1024):\\n\",\n",
    "    \"                    if not chunk:\\n\",\n",
    "    \"                        continue\\n\",\n",
    "    \"                    f.write(chunk)\\n\",\n",
    "    \"                    done += len(chunk)\\n\",\n",
    "    \"                    if total:\\n\",\n",
    "    \"                        self.progress.value = start + min(done / total, 1.0) * (end - start)\\n\",\n",
    "    \"            if total:\\n\",\n",
    "    \"                self._log(f\\\"Downloaded {_format_bytes(done)}.\\\")\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                self._log(f\\\"Downloaded {_format_bytes(destination.stat().st_size)}.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _decrypt_bundle(self, encrypted_path: Path, output_path: Path, password: str, encryption: dict):\\n\",\n",
    "    \"        if encryption.get(\\\"algorithm\\\") != \\\"AES-256-GCM\\\":\\n\",\n",
    "    \"            raise RuntimeError(f\\\"Unsupported encryption algorithm: {encryption.get('algorithm')}\\\")\\n\",\n",
    "    \"        if encryption.get(\\\"kdf\\\") != \\\"PBKDF2-HMAC-SHA256\\\":\\n\",\n",
    "    \"            raise RuntimeError(f\\\"Unsupported KDF: {encryption.get('kdf')}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        salt = _b64decode(encryption[\\\"salt_b64\\\"])\\n\",\n",
    "    \"        nonce = _b64decode(encryption[\\\"nonce_b64\\\"])\\n\",\n",
    "    \"        tag = _b64decode(encryption[\\\"tag_b64\\\"])\\n\",\n",
    "    \"        aad = _b64decode(encryption.get(\\\"aad_b64\\\", base64.b64encode(b\\\"visolabel-colab-bundle-v1\\\").decode(\\\"ascii\\\")))\\n\",\n",
    "    \"        iterations = int(encryption.get(\\\"kdf_iterations\\\", 200000))\\n\",\n",
    "    \"        kdf = PBKDF2HMAC(algorithm=hashes.SHA256(), length=32, salt=salt, iterations=iterations)\\n\",\n",
    "    \"        key = kdf.derive(password.encode(\\\"utf-8\\\"))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        decryptor = Cipher(algorithms.AES(key), modes.GCM(nonce, tag)).decryptor()\\n\",\n",
    "    \"        decryptor.authenticate_additional_data(aad)\\n\",\n",
    "    \"        with open(encrypted_path, \\\"rb\\\") as src, open(output_path, \\\"wb\\\") as dst:\\n\",\n",
    "    \"            for chunk in iter(lambda: src.read(1024 * 1024), b\\\"\\\"):\\n\",\n",
    "    \"                data = decryptor.update(chunk)\\n\",\n",
    "    \"                if data:\\n\",\n",
    "    \"                    dst.write(data)\\n\",\n",
    "    \"            data = decryptor.finalize()\\n\",\n",
    "    \"            if data:\\n\",\n",
    "    \"                dst.write(data)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _extract_manifest(self):\\n\",\n",
    "    \"        if BUNDLE_DIR.exists():\\n\",\n",
    "    \"            shutil.rmtree(BUNDLE_DIR)\\n\",\n",
    "    \"        BUNDLE_DIR.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"        _safe_extract_zip(BUNDLE_ZIP, BUNDLE_DIR)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        manifest_path = BUNDLE_DIR / \\\"training_bundle.json\\\"\\n\",\n",
    "    \"        with open(manifest_path, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n\",\n",
    "    \"            self.manifest = json.load(f)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.task = self.manifest[\\\"task\\\"][\\\"task_type\\\"]\\n\",\n",
    "    \"        self.command = self.manifest[\\\"task\\\"][\\\"command\\\"]\\n\",\n",
    "    \"        self.cfg = self.manifest[\\\"training_config\\\"]\\n\",\n",
    "    \"        self.dataset_dir = BUNDLE_DIR / self.manifest[\\\"paths\\\"][\\\"dataset_dir\\\"]\\n\",\n",
    "    \"        self.train_button.disabled = False\\n\",\n",
    "    \"        self._render_summary()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def resolve_bundle(self):\\n\",\n",
    "    \"        self.token_value = self.token.value.strip() or os.environ.get(\\\"VISOLABEL_TOKEN\\\", \\\"\\\").strip()\\n\",\n",
    "    \"        if not self.token_value:\\n\",\n",
    "    \"            raise RuntimeError(\\\"Paste a VisoLabel token first.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.api_base_url = self.api_url.value.strip() or DEFAULT_API_BASE_URL\\n\",\n",
    "    \"        self.api_token = self.token_value\\n\",\n",
    "    \"        self.encrypted = False\\n\",\n",
    "    \"        self.training_finished = False\\n\",\n",
    "    \"        self.started_at = time.time()\\n\",\n",
    "    \"        self.progress.value = 0\\n\",\n",
    "    \"        self._reset_run_files()\\n\",\n",
    "    \"        self._set_status(\\\"Resolving bundle\\\", \\\"Downloading bundle metadata and preparing the dataset.\\\", \\\"active\\\")\\n\",\n",
    "    \"        self._log(\\\"Resolving token.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if self.token_value.startswith(TOKEN_PREFIX) or self.token_value.startswith(LEGACY_TOKEN_PREFIX):\\n\",\n",
    "    \"            prefix = TOKEN_PREFIX if self.token_value.startswith(TOKEN_PREFIX) else LEGACY_TOKEN_PREFIX\\n\",\n",
    "    \"            payload = json.loads(_b64url_decode(self.token_value[len(prefix):]).decode(\\\"utf-8\\\"))\\n\",\n",
    "    \"            if isinstance(payload, list):\\n\",\n",
    "    \"                bundle_id = \\\"\\\"\\n\",\n",
    "    \"                self.api_token = str(payload[0]) if len(payload) >= 1 else \\\"\\\"\\n\",\n",
    "    \"                password = str(payload[1]) if len(payload) >= 2 else \\\"\\\"\\n\",\n",
    "    \"                bundle_url = \\\"\\\"\\n\",\n",
    "    \"                encryption = {}\\n\",\n",
    "    \"                if len(payload) >= 3:\\n\",\n",
    "    \"                    if isinstance(payload[2], str):\\n\",\n",
    "    \"                        self.api_base_url = payload[2].rstrip(\\\"/\\\") if payload[2] else self.api_base_url\\n\",\n",
    "    \"                    elif isinstance(payload[2], dict):\\n\",\n",
    "    \"                        encryption = _normalize_encryption_metadata(payload[2])\\n\",\n",
    "    \"                if len(payload) >= 4 and isinstance(payload[3], dict):\\n\",\n",
    "    \"                    encryption = _normalize_encryption_metadata(payload[3])\\n\",\n",
    "    \"                self.api_url.value = self.api_base_url\\n\",\n",
    "    \"            elif isinstance(payload, dict):\\n\",\n",
    "    \"                self.api_base_url = payload.get(\\\"api_base_url\\\") or payload.get(\\\"u\\\") or self.api_base_url\\n\",\n",
    "    \"                self.api_url.value = self.api_base_url\\n\",\n",
    "    \"                has_explicit_server_token = \\\"server_token\\\" in payload or \\\"t\\\" in payload\\n\",\n",
    "    \"                bundle_id = payload.get(\\\"bundle_id\\\") or payload.get(\\\"i\\\") or (payload.get(\\\"b\\\") if has_explicit_server_token else \\\"\\\") or \\\"\\\"\\n\",\n",
    "    \"                self.api_token = payload.get(\\\"server_token\\\") or payload.get(\\\"t\\\") or payload.get(\\\"b\\\") or \\\"\\\"\\n\",\n",
    "    \"                bundle_url = payload.get(\\\"bundle_url\\\") or \\\"\\\"\\n\",\n",
    "    \"                password = payload.get(\\\"password\\\") or payload.get(\\\"p\\\") or \\\"\\\"\\n\",\n",
    "    \"                encryption = _extract_encryption_metadata(payload)\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                raise RuntimeError(\\\"Unsupported encrypted VisoLabel token payload.\\\")\\n\",\n",
    "    \"            self.encrypted = True\\n\",\n",
    "    \"            if not self.api_token:\\n\",\n",
    "    \"                raise RuntimeError(\\\"server_token or bundle_id missing in encrypted VisoLabel token.\\\")\\n\",\n",
    "    \"            if not bundle_url or not encryption:\\n\",\n",
    "    \"                resolve_payload = {\\\"token\\\": self.api_token}\\n\",\n",
    "    \"                if bundle_id:\\n\",\n",
    "    \"                    resolve_payload[\\\"bundle_id\\\"] = bundle_id\\n\",\n",
    "    \"                resolve = self._post(\\\"/api/v1/colab/resolve-token/\\\", resolve_payload)\\n\",\n",
    "    \"                bundle_url = bundle_url or _extract_bundle_url(resolve)\\n\",\n",
    "    \"                encryption = encryption or _extract_encryption_metadata(resolve)\\n\",\n",
    "    \"            if not bundle_url or not password or not encryption:\\n\",\n",
    "    \"                missing = []\\n\",\n",
    "    \"                if not bundle_url:\\n\",\n",
    "    \"                    missing.append(\\\"bundle_url\\\")\\n\",\n",
    "    \"                if not password:\\n\",\n",
    "    \"                    missing.append(\\\"password\\\")\\n\",\n",
    "    \"                if not encryption:\\n\",\n",
    "    \"                    missing.append(\\\"encryption metadata\\\")\\n\",\n",
    "    \"                raise RuntimeError(\\\"Encrypted token could not resolve \\\" + \\\", \\\".join(missing) + \\\". Regenerate the token with the latest VisoLabel build or update the resolve-token API to return encryption metadata.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"            self.progress.value = 5\\n\",\n",
    "    \"            self._log(\\\"Downloading encrypted bundle.\\\")\\n\",\n",
    "    \"            self._download(bundle_url, BUNDLE_ENCRYPTED, 5, 30)\\n\",\n",
    "    \"            expected_cipher_sha = encryption.get(\\\"ciphertext_sha256\\\", \\\"\\\")\\n\",\n",
    "    \"            if expected_cipher_sha and _sha256(BUNDLE_ENCRYPTED) != expected_cipher_sha:\\n\",\n",
    "    \"                raise RuntimeError(\\\"Encrypted bundle SHA-256 does not match token metadata.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"            self._set_status(\\\"Decrypting bundle\\\", \\\"The dataset is decrypted locally in this Colab runtime.\\\", \\\"active\\\")\\n\",\n",
    "    \"            self._log(\\\"Decrypting bundle locally.\\\")\\n\",\n",
    "    \"            self.progress.value = 35\\n\",\n",
    "    \"            self._decrypt_bundle(BUNDLE_ENCRYPTED, BUNDLE_ZIP, password, encryption)\\n\",\n",
    "    \"            expected_plain_sha = encryption.get(\\\"plaintext_sha256\\\", \\\"\\\")\\n\",\n",
    "    \"            if expected_plain_sha and _sha256(BUNDLE_ZIP) != expected_plain_sha:\\n\",\n",
    "    \"                raise RuntimeError(\\\"Decrypted bundle SHA-256 does not match token metadata.\\\")\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            resolve = self._post(\\\"/api/v1/colab/resolve-token/\\\", {\\\"token\\\": self.token_value})\\n\",\n",
    "    \"            bundle_url = resolve.get(\\\"bundle_url\\\", \\\"\\\")\\n\",\n",
    "    \"            if not bundle_url:\\n\",\n",
    "    \"                raise RuntimeError(\\\"bundle_url missing in resolve-token response.\\\")\\n\",\n",
    "    \"            self.progress.value = 10\\n\",\n",
    "    \"            self._log(\\\"Downloading bundle.\\\")\\n\",\n",
    "    \"            self._download(bundle_url, BUNDLE_ZIP, 10, 40)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self._set_status(\\\"Extracting bundle\\\", \\\"Reading the manifest and dataset layout.\\\", \\\"active\\\")\\n\",\n",
    "    \"        self.progress.value = 45\\n\",\n",
    "    \"        self._extract_manifest()\\n\",\n",
    "    \"        self.progress.value = 50\\n\",\n",
    "    \"        self._log(f\\\"Resolved {self.task} bundle with command '{self.command}'.\\\")\\n\",\n",
    "    \"        self._set_status(\\\"Bundle ready\\\", \\\"Review the preview, then start training.\\\", \\\"ok\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def train(self):\\n\",\n",
    "    \"        if not self.manifest:\\n\",\n",
    "    \"            self.resolve_bundle()\\n\",\n",
    "    \"        self.upload_button.disabled = True\\n\",\n",
    "    \"        self._set_status(\\\"Training\\\", \\\"Training output appears in the logs below.\\\", \\\"active\\\")\\n\",\n",
    "    \"        self.progress.value = max(self.progress.value, 52)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if self.command == \\\"train\\\":\\n\",\n",
    "    \"            self._train_rfdetr()\\n\",\n",
    "    \"        elif self.command == \\\"classify\\\":\\n\",\n",
    "    \"            self._train_classifier()\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            raise RuntimeError(f\\\"Unsupported command: {self.command}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.progress.value = 90\\n\",\n",
    "    \"        self.training_finished = True\\n\",\n",
    "    \"        self.upload_button.disabled = False\\n\",\n",
    "    \"        self._set_status(\\\"Training finished\\\", f\\\"Outputs are in {OUTPUT_DIR}.\\\", \\\"ok\\\")\\n\",\n",
    "    \"        self._log(f\\\"Training finished. Output dir: {OUTPUT_DIR}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _train_rfdetr(self):\\n\",\n",
    "    \"        self._log(\\\"Installing RF-DETR dependencies.\\\")\\n\",\n",
    "    \"        _install_package(\\\"rfdetr[train,loggers]\\\")\\n\",\n",
    "    \"        os.environ.setdefault(\\\"TORCHDYNAMO_DISABLE\\\", \\\"1\\\")\\n\",\n",
    "    \"        import torch\\n\",\n",
    "    \"        from rfdetr import RFDETRBase, RFDETRLarge\\n\",\n",
    "    \"        from rfdetr import RFDETRSegLarge, RFDETRSegMedium, RFDETRSegNano, RFDETRSegSmall\\n\",\n",
    "    \"\\n\",\n",
    "    \"        model_name = str(self.cfg[\\\"model_name\\\"])\\n\",\n",
    "    \"        task_type = self.manifest[\\\"task\\\"][\\\"task_type\\\"]\\n\",\n",
    "    \"        is_segmentation = task_type == \\\"instance_segmentation\\\"\\n\",\n",
    "    \"        resolution = int(self.cfg.get(\\\"image_size\\\", 560))\\n\",\n",
    "    \"        requested_batch_size = int(self.cfg.get(\\\"batch_size\\\", 4))\\n\",\n",
    "    \"        batch_size = min(requested_batch_size, 2) if is_segmentation else requested_batch_size\\n\",\n",
    "    \"        if batch_size != requested_batch_size:\\n\",\n",
    "    \"            self._log(f\\\"Using Colab-safe segmentation batch size {batch_size} instead of requested {requested_batch_size}.\\\")\\n\",\n",
    "    \"        gpu_name = torch.cuda.get_device_name(0) if torch.cuda.is_available() else \\\"CPU\\\"\\n\",\n",
    "    \"        self._log(f\\\"Runtime device: {gpu_name}; resolution={resolution}; batch_size={batch_size}; AMP disabled.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if is_segmentation:\\n\",\n",
    "    \"            if model_name.endswith(\\\"-L\\\"):\\n\",\n",
    "    \"                model = RFDETRSegLarge(resolution=resolution, amp=False)\\n\",\n",
    "    \"            elif model_name.endswith(\\\"-M\\\"):\\n\",\n",
    "    \"                model = RFDETRSegMedium(resolution=resolution, amp=False)\\n\",\n",
    "    \"            elif model_name.endswith(\\\"-S\\\"):\\n\",\n",
    "    \"                model = RFDETRSegSmall(resolution=resolution, amp=False)\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                model = RFDETRSegNano(resolution=resolution, amp=False)\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            model = RFDETRLarge(resolution=resolution, amp=False) if model_name.endswith(\\\"-L\\\") else RFDETRBase(resolution=resolution, amp=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self._log(f\\\"Starting {model_name} training. RF-DETR will show detailed progress below.\\\")\\n\",\n",
    "    \"        # IMPORTANT: do NOT wrap model.train() in `with self.log_output:`.\\n\",\n",
    "    \"        # Lightning's progress bar (tqdm/Rich Live) uses carriage-return\\n\",\n",
    "    \"        # updates and ANSI cursor controls that the ipywidgets Output\\n\",\n",
    "    \"        # widget cannot render — output buffers fill up and the run\\n\",\n",
    "    \"        # appears frozen after \\\"Loading train_dataloader to estimate\\n\",\n",
    "    \"        # number of stepping batches\\\". We also disable tqdm entirely\\n\",\n",
    "    \"        # (progress_bar=False) for the same reason the local backend\\n\",\n",
    "    \"        # does it: CR-only writes deadlock on captured streams.\\n\",\n",
    "    \"        train_kwargs = dict(\\n\",\n",
    "    \"            dataset_dir=str(self.dataset_dir),\\n\",\n",
    "    \"            epochs=int(self.cfg.get(\\\"epochs\\\", 50)),\\n\",\n",
    "    \"            batch_size=batch_size,\\n\",\n",
    "    \"            lr=float(self.cfg.get(\\\"learning_rate\\\", 1e-4)),\\n\",\n",
    "    \"            output_dir=str(OUTPUT_DIR),\\n\",\n",
    "    \"            class_names=self.cfg.get(\\\"classes\\\", []),\\n\",\n",
    "    \"            num_workers=0,\\n\",\n",
    "    \"            persistent_workers=False,\\n\",\n",
    "    \"            multi_scale=False,\\n\",\n",
    "    \"            expanded_scales=False,\\n\",\n",
    "    \"            compute_val_loss=False,\\n\",\n",
    "    \"            compute_test_loss=False,\\n\",\n",
    "    \"            log_every_n_steps=1,\\n\",\n",
    "    \"            tensorboard=False,\\n\",\n",
    "    \"            progress_bar=False,\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"        total_epochs = int(train_kwargs[\\\"epochs\\\"])\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            model.callbacks[\\\"on_fit_epoch_end\\\"].append(\\n\",\n",
    "    \"                lambda info: (\\n\",\n",
    "    \"                    self._log(\\n\",\n",
    "    \"                        f\\\"Epoch {int(info.get('epoch', 0)) + 1}/{total_epochs} - \\\"\\n\",\n",
    "    \"                        + ', '.join(\\n\",\n",
    "    \"                            f\\\"{k}={v:.4f}\\\" if isinstance(v, float) else f\\\"{k}={v}\\\"\\n\",\n",
    "    \"                            for k, v in info.items() if k != 'epoch'\\n\",\n",
    "    \"                        )\\n\",\n",
    "    \"                    ),\\n\",\n",
    "    \"                    setattr(self.progress, 'value', 55 + ((int(info.get('epoch', 0)) + 1) / max(total_epochs, 1)) * 33),\\n\",\n",
    "    \"                )\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"        except Exception as cb_exc:\\n\",\n",
    "    \"            self._log(f\\\"Could not register epoch callback: {cb_exc}\\\")\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            model.train(**train_kwargs)\\n\",\n",
    "    \"        except TypeError as exc:\\n\",\n",
    "    \"            # Older rfdetr versions may not accept progress_bar=False; retry without it.\\n\",\n",
    "    \"            if \\\"progress_bar\\\" in str(exc):\\n\",\n",
    "    \"                self._log(\\\"rfdetr does not support progress_bar=False; retrying without it.\\\")\\n\",\n",
    "    \"                train_kwargs.pop(\\\"progress_bar\\\", None)\\n\",\n",
    "    \"                model.train(**train_kwargs)\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                raise\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _train_classifier(self):\\n\",\n",
    "    \"        self._log(\\\"Installing classifier dependencies.\\\")\\n\",\n",
    "    \"        _install_package(\\\"timm\\\")\\n\",\n",
    "    \"        import timm\\n\",\n",
    "    \"        import torch\\n\",\n",
    "    \"        import torch.nn as nn\\n\",\n",
    "    \"        import torch.optim as optim\\n\",\n",
    "    \"        from torch.utils.data import DataLoader\\n\",\n",
    "    \"        from torchvision import datasets, transforms\\n\",\n",
    "    \"\\n\",\n",
    "    \"        image_size = int(self.cfg.get(\\\"image_size\\\", 224))\\n\",\n",
    "    \"        batch_size = int(self.cfg.get(\\\"batch_size\\\", 16))\\n\",\n",
    "    \"        epochs = int(self.cfg.get(\\\"epochs\\\", 30))\\n\",\n",
    "    \"        train_ds = datasets.ImageFolder(str(self.dataset_dir / \\\"train\\\"), transform=transforms.Compose([\\n\",\n",
    "    \"            transforms.RandomResizedCrop(image_size),\\n\",\n",
    "    \"            transforms.RandomHorizontalFlip(),\\n\",\n",
    "    \"            transforms.ToTensor(),\\n\",\n",
    "    \"        ]))\\n\",\n",
    "    \"        valid_path = self.dataset_dir / \\\"valid\\\"\\n\",\n",
    "    \"        val_ds = datasets.ImageFolder(str(valid_path), transform=transforms.Compose([\\n\",\n",
    "    \"            transforms.Resize(int(image_size * 1.14)),\\n\",\n",
    "    \"            transforms.CenterCrop(image_size),\\n\",\n",
    "    \"            transforms.ToTensor(),\\n\",\n",
    "    \"        ])) if valid_path.exists() else None\\n\",\n",
    "    \"\\n\",\n",
    "    \"        train_loader = DataLoader(train_ds, batch_size=batch_size, shuffle=True, num_workers=2)\\n\",\n",
    "    \"        val_loader = DataLoader(val_ds, batch_size=batch_size, shuffle=False, num_workers=2) if val_ds else None\\n\",\n",
    "    \"        model_name = str(self.cfg.get(\\\"model_name\\\", \\\"convnext_tiny.fb_in22k_ft_in1k\\\"))\\n\",\n",
    "    \"        model = timm.create_model(model_name, pretrained=True, num_classes=len(train_ds.classes))\\n\",\n",
    "    \"        device = \\\"cuda\\\" if torch.cuda.is_available() else \\\"cpu\\\"\\n\",\n",
    "    \"        model = model.to(device)\\n\",\n",
    "    \"        criterion = nn.CrossEntropyLoss()\\n\",\n",
    "    \"        optimizer = optim.AdamW(model.parameters(), lr=float(self.cfg.get(\\\"learning_rate\\\", 1e-4)))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        best_path = OUTPUT_DIR / \\\"checkpoint_best_total.pth\\\"\\n\",\n",
    "    \"        best_acc = 0.0\\n\",\n",
    "    \"        self._log(f\\\"Starting {model_name} classification training on {device}.\\\")\\n\",\n",
    "    \"        for epoch in range(epochs):\\n\",\n",
    "    \"            model.train()\\n\",\n",
    "    \"            epoch_loss = 0.0\\n\",\n",
    "    \"            with self.log_output:\\n\",\n",
    "    \"                batches = tqdm(train_loader, desc=f\\\"Epoch {epoch + 1}/{epochs}\\\", leave=False)\\n\",\n",
    "    \"                for x, y in batches:\\n\",\n",
    "    \"                    x, y = x.to(device), y.to(device)\\n\",\n",
    "    \"                    optimizer.zero_grad()\\n\",\n",
    "    \"                    loss = criterion(model(x), y)\\n\",\n",
    "    \"                    loss.backward()\\n\",\n",
    "    \"                    optimizer.step()\\n\",\n",
    "    \"                    epoch_loss += float(loss.item())\\n\",\n",
    "    \"                    batches.set_postfix(loss=f\\\"{loss.item():.4f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if val_loader:\\n\",\n",
    "    \"                model.eval()\\n\",\n",
    "    \"                total = 0\\n\",\n",
    "    \"                correct = 0\\n\",\n",
    "    \"                with torch.no_grad():\\n\",\n",
    "    \"                    for x, y in val_loader:\\n\",\n",
    "    \"                        x, y = x.to(device), y.to(device)\\n\",\n",
    "    \"                        pred = model(x).argmax(1)\\n\",\n",
    "    \"                        total += y.shape[0]\\n\",\n",
    "    \"                        correct += (pred == y).sum().item()\\n\",\n",
    "    \"                acc = (correct / max(total, 1)) * 100.0\\n\",\n",
    "    \"                if acc >= best_acc:\\n\",\n",
    "    \"                    best_acc = acc\\n\",\n",
    "    \"                    torch.save({\\\"model_state_dict\\\": model.state_dict(), \\\"classes\\\": train_ds.classes}, best_path)\\n\",\n",
    "    \"                self._log(f\\\"Epoch {epoch + 1}/{epochs}: validation accuracy {acc:.2f}%\\\")\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                self._log(f\\\"Epoch {epoch + 1}/{epochs}: loss {epoch_loss / max(len(train_loader), 1):.4f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"            self.progress.value = 55 + ((epoch + 1) / max(epochs, 1)) * 35\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if not best_path.exists():\\n\",\n",
    "    \"            torch.save({\\\"model_state_dict\\\": model.state_dict(), \\\"classes\\\": train_ds.classes}, best_path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _request_upload(self, path: Path) -> dict:\\n\",\n",
    "    \"        return self._post(\\\"/api/v1/colab/request-checkpoint-upload/\\\", {\\n\",\n",
    "    \"            \\\"token\\\": self.api_token,\\n\",\n",
    "    \"            \\\"file_name\\\": path.name,\\n\",\n",
    "    \"            \\\"file_size\\\": path.stat().st_size,\\n\",\n",
    "    \"        })\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _upload_artifact(self, path: Path, index: int, total: int):\\n\",\n",
    "    \"        request = self._request_upload(path)\\n\",\n",
    "    \"        upload_url = request.get(\\\"upload_url\\\", \\\"\\\")\\n\",\n",
    "    \"        if not upload_url:\\n\",\n",
    "    \"            raise RuntimeError(f\\\"upload_url missing for {path.name}\\\")\\n\",\n",
    "    \"        method = str(request.get(\\\"upload_method\\\", \\\"PUT\\\")).upper()\\n\",\n",
    "    \"        headers = request.get(\\\"upload_headers\\\", {}) or {}\\n\",\n",
    "    \"        headers.pop(\\\"Host\\\", None)\\n\",\n",
    "    \"        self._log(f\\\"Uploading {path.name} ({_format_bytes(path.stat().st_size)}).\\\")\\n\",\n",
    "    \"        with open(path, \\\"rb\\\") as f:\\n\",\n",
    "    \"            if method == \\\"POST\\\":\\n\",\n",
    "    \"                response = requests.post(upload_url, files={\\\"file\\\": (path.name, f)}, headers=headers, timeout=600)\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                response = requests.put(upload_url, data=f, headers=headers, timeout=600)\\n\",\n",
    "    \"        response.raise_for_status()\\n\",\n",
    "    \"        self.progress.value = 90 + (index / max(total, 1)) * 8\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def upload(self):\\n\",\n",
    "    \"        if not self.api_token:\\n\",\n",
    "    \"            raise RuntimeError(\\\"Resolve the bundle before uploading results.\\\")\\n\",\n",
    "    \"        self._set_status(\\\"Uploading results\\\", \\\"Sending checkpoints and logs back to VisoLabel.\\\", \\\"active\\\")\\n\",\n",
    "    \"        self.upload_list = sorted(p for p in OUTPUT_DIR.rglob(\\\"*\\\") if p.is_file() and p.suffix.lower() in ARTIFACT_EXTENSIONS)\\n\",\n",
    "    \"        if not self.upload_list:\\n\",\n",
    "    \"            self._log(\\\"No uploadable artifacts found.\\\")\\n\",\n",
    "    \"        for index, path in enumerate(self.upload_list, start=1):\\n\",\n",
    "    \"            self._upload_artifact(path, index, len(self.upload_list))\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            self._post(\\\"/api/v1/colab/finalize-run/\\\", {\\\"token\\\": self.api_token})\\n\",\n",
    "    \"        except Exception as exc:\\n\",\n",
    "    \"            self._log(f\\\"Finalize endpoint not available: {exc}\\\")\\n\",\n",
    "    \"        elapsed = int(time.time() - self.started_at) if self.started_at else 0\\n\",\n",
    "    \"        self.progress.value = 100\\n\",\n",
    "    \"        self._set_status(\\\"Complete\\\", f\\\"Pipeline finished in {elapsed // 60}m {elapsed % 60}s.\\\", \\\"ok\\\")\\n\",\n",
    "    \"        self._log(\\\"Upload complete.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _set_busy(self, busy: bool):\\n\",\n",
    "    \"        self.run_button.disabled = busy\\n\",\n",
    "    \"        self.resolve_button.disabled = busy\\n\",\n",
    "    \"        self.train_button.disabled = busy or self.manifest is None\\n\",\n",
    "    \"        self.upload_button.disabled = busy or not self.api_token or not self.training_finished\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _run_action(self, action):\\n\",\n",
    "    \"        self._set_busy(True)\\n\",\n",
    "    \"        try:\\n\",\n",
    "    \"            action()\\n\",\n",
    "    \"        except Exception as exc:\\n\",\n",
    "    \"            self._set_status(\\\"Error\\\", str(exc), \\\"error\\\")\\n\",\n",
    "    \"            self._log(f\\\"Error: {exc}\\\")\\n\",\n",
    "    \"            raise\\n\",\n",
    "    \"        finally:\\n\",\n",
    "    \"            self._set_busy(False)\\n\",\n",
    "    \"            self._render_summary()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _on_resolve(self, _):\\n\",\n",
    "    \"        self._run_action(self.resolve_bundle)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _on_train(self, _):\\n\",\n",
    "    \"        self._run_action(self.train)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _on_upload(self, _):\\n\",\n",
    "    \"        self._run_action(self.upload)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _on_run_full(self, _):\\n\",\n",
    "    \"        def pipeline():\\n\",\n",
    "    \"            self.resolve_bundle()\\n\",\n",
    "    \"            self.train()\\n\",\n",
    "    \"            self.upload()\\n\",\n",
    "    \"        self._run_action(pipeline)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"gui = VisoLabelColabGUI()\\n\",\n",
    "    \"gui.display()\\n\"\n",
    "   ]\n",
    "  }\n",
